{
  "name": "claude-mcp",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP Chat CLI - TypeScript port",
  "scripts": {
    "start": "tsx src/main.ts",
    "start:mcp-client": "tsx src/mcp-client.ts",
    "debug": "tsx --inspect-brk src/main.ts",
    "format": "prettier --write src",
    "inspect": "npx @modelcontextprotocol/inspector tsx src/mcp-server.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
